# ============================================================
# Firebase Configuration
# Copy this file to .env and fill in your real values.
# Get these from Firebase Console > Project Settings > Web App
# ============================================================
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================
# Google Apps Script Webhook URL (SERVER-SIDE ONLY)
# Deploy your Google Apps Script and paste the execution URL.
# This must NEVER be placed in frontend code.
# ============================================================
WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ============================================================
# Default admin notification email
# ============================================================
ADMIN_EMAIL=your_admin_email@example.com
VITE_ADMIN_EMAIL=your_admin_email@example.com

# ============================================================
# Server config
# ============================================================
PORT=5000
ALLOWED_ORIGIN=http://localhost:5173
NODE_ENV=development
